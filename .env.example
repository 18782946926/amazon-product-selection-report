# LLM Provider 选择：qwen（推荐）| doubao
# 注意：deepseek 已停用（公共 API 不支持视觉），保留字符串只会抛 LLMUnavailable
LLM_PROVIDER=qwen

# 通义千问（DashScope，文本 + 视觉一体，主路径）
DASHSCOPE_API_KEY=
QWEN_FAST_MODEL=qwen-plus
QWEN_SMART_MODEL=qwen-max
QWEN_VISION_MODEL=qwen-vl-max

# 视觉二审 audit 范围：low_conf（最省）/ suspect（推荐）/ all（最彻底）
VISION_AUDIT_MODE=suspect

# 豆包（火山方舟，可选备选）
ARK_API_KEY=
DOUBAO_FAST_MODEL=doubao-1-5-lite-32k-250115
DOUBAO_SMART_MODEL=doubao-1-5-pro-32k-250115

# 单独配置视觉 provider（可选）：当主 LLM_PROVIDER 不支持视觉时启用
# VISION_PROVIDER=qwen

# LLM 调用通用配置
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
LLM_CACHE_DIR=llm_cache
# 缓存复用策略：默认（=0/未设）每次 /upload 清非 vision 缓存（重传=重跑语义）；
# =1 复用所有缓存（dev 迭代 Excel 渲染时省 LLM 钱）。vision_classify_* 始终保留。
LLM_CACHE_REUSE=0

# VOC 评论聚类并发
VOC_MAX_WORKERS=10

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=8001
